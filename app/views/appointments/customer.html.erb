<%= h2 do %>
  <% if @appointment.updated? %>
    Your Pension Wise <%= @appointment.type_label %> has been updated
  <% else %>
    Your Pension Wise <%= @appointment.type_label %> is confirmed
  <% end %>
<% end %>

<%= p do %>
  <strong>Reference number:</strong> <%= @appointment.reference %>
<% end %>

<%= p do %>
  Dear <%= @appointment.name %>,
<% end %>

<%= p do %>
  <% if @appointment.updated? %>
    Your new Pension Wise <%= @appointment.type_label %> is booked for: 
  <% else %>
    Your Pension Wise <%= @appointment.type_label %> is booked for: 
  <% end %>
<% end %>

<%= render 'shared/email/appointment_details' %>

<%= render 'shared/email/change_or_cancel' %>

<%= render 'shared/email/preparing_for_appointment' %>

<%= render 'shared/email/money_helper' %>
